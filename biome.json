{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "main"
  },
  "files": {
    "ignoreUnknown": true,
    "ignore": [
      "**/dist",
      "**/build",
      "**/.next",
      "**/.turbo",
      "**/node_modules",
      "**/coverage",
      "**/.vercel",
      "**/.supabase",
      "**/.output",
      "**/firmware/watcher/build",
      "**/firmware/watcher/managed_components",
      "**/firmware/watcher/sdkconfig*",
      "**/packages/shared-types/src/database.ts",
      "**/*.min.js",
      "**/*.lock",
      "**/bun.lockb"
    ]
  },
  "organizeImports": { "enabled": true },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "trailingCommas": "all",
      "semicolons": "asNeeded",
      "arrowParentheses": "always"
    }
  },
  "json": {
    "formatter": { "trailingCommas": "none" }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "useImportType": "error",
        "useExportType": "error",
        "useNodejsImportProtocol": "error",
        "useConst": "error",
        "useTemplate": "warn",
        "noNonNullAssertion": "warn"
      },
      "suspicious": {
        "noExplicitAny": "warn",
        "noConsoleLog": "off",
        "noConsole": { "level": "warn", "options": { "allow": ["warn", "error", "info"] } }
      },
      "correctness": {
        "noUnusedVariables": "error",
        "noUnusedImports": "error"
      },
      "complexity": {
        "noBannedTypes": "error",
        "noUselessFragments": "error"
      },
      "a11y": {
        "useKeyWithClickEvents": "off"
      }
    }
  },
  "overrides": [
    {
      "include": ["services/cloud/functions/**/*.ts"],
      "linter": {
        "rules": {
          "style": { "useNodejsImportProtocol": "off" }
        }
      }
    },
    {
      "include": ["**/*.test.ts", "**/*.spec.ts"],
      "linter": {
        "rules": {
          "suspicious": { "noExplicitAny": "off" }
        }
      }
    }
  ]
}
