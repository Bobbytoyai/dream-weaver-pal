{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "color": {
    "bobby-violet": { "value": "#9333EA", "$description": "Couleur primaire Bobby" },
    "bobby-violet-90": { "value": "#A855F7" },
    "bobby-violet-50": { "value": "#9333EA80" },
    "bobby-violet-20": { "value": "#9333EA33" },
    "bobby-bg": { "value": "#0A0A0F", "$description": "Fond sombre app" },
    "bobby-bg-card": { "value": "#15151F" },
    "bobby-text": { "value": "#F4F4F8" },
    "bobby-text-muted": { "value": "#A1A1AA" },
    "bobby-success": { "value": "#10B981" },
    "bobby-warning": { "value": "#F59E0B" },
    "bobby-danger": { "value": "#EF4444" }
  },
  "typography": {
    "display": { "value": { "fontFamily": "Quicksand, system-ui", "fontWeight": 600 } },
    "body":    { "value": { "fontFamily": "Inter, system-ui",    "fontWeight": 400 } },
    "mono":    { "value": { "fontFamily": "JetBrains Mono, monospace" } }
