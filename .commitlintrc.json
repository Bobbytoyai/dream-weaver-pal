{
  "extends": ["@commitlint/config-conventional"],
  "rules": {
    "type-enum": [
      2,
      "always",
      ["feat", "fix", "docs", "refactor", "test", "chore", "perf", "build", "ci", "revert", "style"]
    ],
    "scope-enum": [
      2,
      "always",
      ["brain", "firmware", "web", "parent-pwa", "cloud", "brand", "sdk", "shared-types", "docs", "ci", "deps", "tools", "repo"]
    ],
    "subject-case": [2, "never", ["upper-case", "pascal-case"]],
    "header-max-length": [2, "always", 100]
  }
}
